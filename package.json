{
  "name": "gaiensai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "update-config": "node ./scripts/update-last-update.mjs",
    "generate:index": "node scripts/generate-index-from-config.mjs",
    "generate:performances": "node scripts/generate-performances-static.mjs",
    "build": "npm run update-config && npm run generate:index && npm run generate:performances && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:vitest": "vitest run",
    "test:deno": "deno task test",
    "test": "eslint . && npm run test:deno && npm run test:vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "preact": "^10.29.7",
    "preact-iso": "^2.12.0",
    "qr-scanner": "^1.4.2",
    "react-icons": "^5.7.0",
    "recharts": "^3.10.0",
    "uqr": "^0.1.2"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.17.3",
    "@eslint/js": "^9.39.2",
    "@preact/preset-vite": "^2.10.6",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.6",
    "supabase": "^2.109.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
